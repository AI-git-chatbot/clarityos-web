// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// For production, we use PostgreSQL (Supabase)
datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  image         String?
  apiToken      String    @unique @default(uuid()) // Used by the desktop app
  
  intentions    DailyIntention[]
  sessions      Session[]
}

model DailyIntention {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  todos          String   // Plain text fallback (used in email reports)
  checklistItems String   @default("[]") // JSON: [{id, text, done}]

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  sessionStart      DateTime
  sessionEnd        DateTime
  durationMinutes   Float
  primaryCategory   String?
  primaryProject    String?
  appsUsed          String?
  aiContextSummary  String?
  contextSwitches   Int      @default(0)
  
  user              User     @relation(fields: [userId], references: [id])
}
